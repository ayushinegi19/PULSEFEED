# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_a_random_64_char_hex_string

# NewsData.io API key
NEWSDATA_API_KEY=your_newsdata_io_api_key_here

# Database URL — Neon Postgres connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: override SQLAlchemy URI directly (defaults to DATABASE_URL or sqlite)
# SQLALCHEMY_DATABASE_URI=sqlite:///database.db

# Cache TTL for news articles in seconds (default: 600 = 10 minutes)
NEWS_CACHE_TTL=600

# NewsData.io request timeout in seconds (default: 15)
NEWSDATA_TIMEOUT=15

# Set to "development" to enable debug mode; anything else = production
FLASK_ENV=production

# Feature flags
ENABLE_HISTORY_RANKING=true
HISTORY_MIN_INTERACTIONS=5
